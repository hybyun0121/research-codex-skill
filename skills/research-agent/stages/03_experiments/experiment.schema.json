{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Experiment Plan",
  "type": "object",
  "properties": {
    "claims": { "type": "array", "items": { "type": "string" } },
    "detail_html": {
      "type": "object",
      "description": "Companion HTML page linked from experiments.plan[].reference so shared rendering does not need script changes.",
      "properties": {
        "path": { "type": "string", "default": "research/experiments-detail.html" },
        "brief_reference": { "type": "string", "default": "experiments-detail.html" },
        "title": { "type": "string" },
        "summary": { "type": "string" }
      }
    },
    "baseline_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paper", "venue_year", "task", "metric"],
        "properties": {
          "method_name": { "type": ["string", "null"] },
          "paper": { "type": "string" },
          "venue_year": { "type": "string" },
          "main_table": { "type": ["string", "null"] },
          "task": { "type": "string" },
          "metric": { "type": "string" },
          "why_competitive": { "type": ["string", "null"] },
          "url": { "type": ["string", "null"] },
          "huggingface_url": { "type": ["string", "null"] },
          "github_url": { "type": ["string", "null"] },
          "code_reuse": {
            "type": ["string", "null"],
            "enum": ["preferred", "possible", "not_available", "not_recommended", "unknown", null]
          }
        }
      }
    },
    "prior_result_leaderboard": {
      "type": "array",
      "description": "Published baseline rows reused from Motivation literature tables when relevant.",
      "items": {
        "type": "object",
        "required": ["method_name", "paper", "dataset", "metric"],
        "properties": {
          "method_name": { "type": "string" },
          "paper": { "type": "string" },
          "source_table": { "type": ["string", "null"] },
          "dataset": { "type": "string" },
          "metric": { "type": "string" },
          "reported_result": { "type": ["string", "number", "null"] },
          "paper_url": { "type": ["string", "null"] },
          "huggingface_url": { "type": ["string", "null"] },
          "github_url": { "type": ["string", "null"] },
          "use_in_this_plan": { "type": ["string", "null"] }
        }
      }
    },
    "plan": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "claim": { "type": "string" },
          "tier": { "type": ["string", "null"], "enum": ["toy", "full", "both", null] },
          "dataset": { "type": "string" },
          "metric": { "type": "string" },
          "baseline": { "type": "string" },
          "evidence": { "type": "string" },
          "reference": { "type": ["string", "null"] }
        }
      }
    },
    "toy_benchmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dataset", "purpose", "metric"],
        "properties": {
          "dataset": { "type": "string" },
          "purpose": { "type": "string" },
          "subset_or_scale": { "type": ["string", "null"] },
          "metric": { "type": "string" },
          "expected_runtime": { "type": ["string", "null"] },
          "success_criterion": { "type": ["string", "null"] },
          "url": { "type": ["string", "null"] }
        }
      }
    },
    "full_benchmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["dataset", "purpose", "metric", "baselines"],
        "properties": {
          "dataset": { "type": "string" },
          "purpose": { "type": "string" },
          "scale": { "type": ["string", "null"] },
          "metric": { "type": "string" },
          "baselines": { "type": "array", "items": { "type": "string" } },
          "required_evidence": { "type": ["string", "null"] },
          "url": { "type": ["string", "null"] }
        }
      }
    },
    "gpu_inventory": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gpu_model", "count", "memory_gb"],
        "properties": {
          "gpu_model": { "type": "string" },
          "count": { "type": "integer" },
          "memory_gb": { "type": "number" },
          "best_use": { "type": ["string", "null"] },
          "constraints": { "type": ["string", "null"] }
        }
      },
      "default": [
        { "gpu_model": "RTX 4090", "count": 4, "memory_gb": 24 },
        { "gpu_model": "RTX A6000", "count": 1, "memory_gb": 48 },
        { "gpu_model": "RTX PRO 6000 Blackwell Server Edition", "count": 3, "memory_gb": 96 }
      ]
    },
    "ablations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "claim_isolated", "control_variant"],
        "properties": {
          "name": { "type": "string" },
          "claim_isolated": { "type": "string" },
          "control_variant": { "type": "string" },
          "expected_signal": { "type": ["string", "null"] },
          "failure_interpretation": { "type": ["string", "null"] }
        }
      }
    },
    "sweeps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "values": { "type": "array" },
          "default": {},
          "budget": { "type": ["string", "null"] },
          "stopping_rule": { "type": ["string", "null"] },
          "expected_signal": { "type": ["string", "null"] },
          "failure_trigger": { "type": ["string", "null"] }
        }
      }
    },
    "compute_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["experiment", "tier", "gpu_recommendation", "gpu_count"],
        "properties": {
          "experiment": { "type": "string" },
          "tier": { "type": "string", "enum": ["toy", "full", "ablation", "sweep", "qualitative"] },
          "gpu_recommendation": { "type": "string" },
          "gpu_count": { "type": ["integer", "string"] },
          "required_memory_gb": { "type": ["number", "string", "null"] },
          "memory_need": { "type": ["string", "null"] },
          "memory_margin": { "type": ["string", "null"] },
          "estimated_runtime": { "type": ["string", "null"] },
          "gpu_hours": { "type": ["number", "string", "null"] },
          "parallelism": { "type": ["string", "null"] },
          "fallback": { "type": ["string", "null"] },
          "rationale": { "type": ["string", "null"] }
        }
      }
    },
    "budget_summary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scope", "recommended_gpu_pool"],
        "properties": {
          "scope": { "type": "string" },
          "runs": { "type": ["integer", "string", "null"] },
          "recommended_gpu_pool": { "type": "string" },
          "total_gpu_hours": { "type": ["number", "string", "null"] },
          "wall_clock_estimate": { "type": ["string", "null"] },
          "budget_risk": { "type": ["string", "null"] },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "reference_code_reuse": {
      "type": "array",
      "description": "Plan for adapting code from reference-paper GitHub repositories after user allows toy execution.",
      "items": {
        "type": "object",
        "required": ["source_paper", "github_url", "reuse_decision"],
        "properties": {
          "source_paper": { "type": "string" },
          "github_url": { "type": "string" },
          "reuse_decision": {
            "type": "string",
            "enum": ["use_as_base", "inspect_first", "do_not_use", "fallback_only"]
          },
          "license_or_use_check": { "type": ["string", "null"] },
          "local_path": { "type": ["string", "null"] },
          "files_to_adapt": { "type": "array", "items": { "type": "string" } },
          "setup_command": { "type": ["string", "null"] },
          "toy_run_command": { "type": ["string", "null"] },
          "patch_summary": { "type": ["string", "null"] },
          "fallback": { "type": ["string", "null"] }
        }
      }
    },
    "toy_execution": {
      "type": "object",
      "properties": {
        "requires_user_approval": { "type": "boolean", "default": true },
        "approval_status": {
          "type": "string",
          "enum": ["not_asked", "approved_setup_only", "approved_toy_run", "declined", "blocked"]
        },
        "environment": {
          "type": "object",
          "properties": {
            "python": { "type": ["string", "null"] },
            "package_manager": { "type": ["string", "null"] },
            "setup_commands": { "type": "array", "items": { "type": "string" } },
            "env_vars_required": { "type": "array", "items": { "type": "string" } }
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["step", "status"],
            "properties": {
              "step": { "type": "string" },
              "command_or_action": { "type": ["string", "null"] },
              "expected_output": { "type": ["string", "null"] },
              "status": {
                "type": "string",
                "enum": ["planned", "running", "complete", "failed", "skipped", "blocked"]
              },
              "notes": { "type": ["string", "null"] }
            }
          }
        },
        "results": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "experiment_id": { "type": "string" },
              "metric": { "type": "string" },
              "value": { "type": ["number", "string", "null"] },
              "artifact": { "type": ["string", "null"] },
              "interpretation": { "type": ["string", "null"] }
            }
          }
        },
        "summary": { "type": ["string", "null"] },
        "next_action": { "type": ["string", "null"] }
      }
    },
    "qualitative": { "type": "array", "items": { "type": "string" } },
    "reproducibility": {
      "type": "object",
      "properties": {
        "code_snapshot": { "type": ["string", "null"] },
        "data_split": { "type": ["string", "null"] },
        "seeds": { "type": "array", "items": { "type": ["integer", "string"] } },
        "logging_artifacts": { "type": "array", "items": { "type": "string" } },
        "statistical_reporting": { "type": ["string", "null"] }
      }
    },
    "risks": { "type": "array", "items": { "type": "string" } }
  }
}
